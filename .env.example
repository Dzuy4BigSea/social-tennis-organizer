# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored; never commit it.

# Supabase project URL.
# Dashboard → Settings → API → "Project URL".
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable (public) API key.
# Dashboard → Settings → API → "Publishable key" (newer projects;
# starts with sb_publishable_) OR "anon public" (older projects).
# Safe to ship in client code — row-level security gates access.
# The service_role key MUST NOT go here; it bypasses RLS.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
